      "type": "generationTable",
      "entries": [
        {
          "path": "App.tsx",
          "generationType": 1,
          "isDone": true,
          "description": "Update the app to support three distinct modes: Text to Image, Mix &amp; Match (multimodal), and Image to Prompt. Added a new tab and updated conditional rendering for inputs.",
          "diffs": [
            {
              "target": "",
              "replacement": "\nimport React, { useState, useCallback } from 'react';\nimport { ImageUploadSlot } from './components/ImageUploadSlot';\nimport { generateImage, generateDescription } from './services/geminiService';\n\ntype AppMode = 'text-to-image' | 'mix-match' | 'describe';\n\nconst App: React.FC = () => {\n  const [mode, setMode] = useState<AppMode>('text-to-image');\n  const [imageFiles, setImageFiles] = useState<(File | null)[]>([null, null, null]);\n  const [imagePreviews, setImagePreviews] = useState<(string | null)[]>([null, null, null]);\n  const [prompt, setPrompt] = useState<string>('');\n  const [isLoading, setIsLoading] = useState<boolean>(false);\n  const [generatedImage, setGeneratedImage] = useState<string | null>(null);\n  const [generatedText, setGeneratedText] = useState<string | null>(null);\n  const [error, setError] = useState<string | null>(null);\n\n  const handleImageSelect = useCallback((index: number, file: File) => {\n    const reader = new FileReader();\n    reader.onloadend = () => {\n      setImagePreviews(prev => {\n        const newPreviews = [...prev];\n        newPreviews[index] = reader.result as string;\n        return newPreviews;\n      });\n      setImageFiles(prev => {\n        const newFiles = [...prev];\n        newFiles[index] = file;\n        return newFiles;\n      });\n    };\n    reader.readAsDataURL(file);\n  }, []);\n\n  const handleImageRemove = useCallback((index: number) => {\n    setImagePreviews(prev => {\n      const newPreviews = [...prev];\n      newPreviews[index] = null;\n      return newPreviews;\n    });\n    setImageFiles(prev => {\n      const newFiles = [...prev];\n      newFiles[index] = null;\n      return newFiles;\n    });\n  }, []);\n  \n  const handleGenerateClick = async () => {\n    const activeImages = imageFiles.filter((f): f is File => f !== null);\n    \n    // Validation based on mode\n    if (mode === 'text-to-image' && !prompt.trim()) {\n      setError(\"Harap berikan prompt untuk menghasilkan gambar.\");\n      return;\n    }\n    if (mode === 'mix-match' && (!prompt.trim() || activeImages.length === 0)) {\n      setError(\"Mode Mix & Match membutuhkan prompt dan setidaknya satu gambar.\");\n      return;\n    }\n    if (mode === 'describe' && activeImages.length === 0) {\n      setError(\"Harap unggah setidaknya satu gambar untuk diekstrak promptnya.\");\n      return;\n    }\n\n    setIsLoading(true);\n    setError(null);\n    setGeneratedImage(null);\n    setGeneratedText(null);\n\n    try {\n      if (mode === 'text-to-image' || mode === 'mix-match') {\n        const result = await generateImage(prompt, activeImages);\n        setGeneratedImage(result);\n      } else {\n        const result = await generateDescription(activeImages);\n        setGeneratedText(result);\n      }\n    } catch (err) {\n      console.error(err);\n      setError(err instanceof Error ? err.message : \"Terjadi kesalahan yang tidak diketahui.\");\n    } finally {\n      setIsLoading(false);\n    }\n  };\n\n  const downloadImage = () => {\n    if (!generatedImage) return;\n    const link = document.createElement('a');\n    link.href = generatedImage;\n    link.download = `triattach-generated-${Date.now()}.png`;\n    document.body.appendChild(link);\n    link.click();\n    document.body.removeChild(link);\n  };\n\n  const isGenerationDisabled = isLoading || (mode === 'text-to-image' ? !prompt.trim() : false);\n\n  return (\n    <div className=\"bg-gray-900 text-white min-h-screen font-sans\">\n      <div className=\"container mx-auto px-4 py-8\">\n        <header className=\"text-center mb-10\">\n          <h1 className=\"text-4xl sm:text-5xl font-extrabold text-transparent bg-clip-text bg-gradient-to-r from-purple-400 to-indigo-600\">\n            TriAttach Image Generator\n          </h1>\n          <p className=\"mt-4 text-lg text-gray-400 max-w-2xl mx-auto\">\n            Platform AI 3-dalam-1 untuk kreasi visual: Text-to-Image, Mix & Match, dan Image-to-Prompt.\n          </p>\n        </header>\n\n        <main className=\"grid grid-cols-1 lg:grid-cols-2 gap-8\">\n          {/* Input Panel */}\n          <div className=\"bg-gray-800/50 backdrop-blur-sm rounded-2xl p-6 shadow-2xl border border-gray-700 flex flex-col space-y-6\">\n            \n            {/* Mode Tabs */}\n            <div className=\"grid grid-cols-3 gap-1 p-1 bg-gray-900/50 rounded-xl\">\n              <button\n                onClick={() => setMode('text-to-image')}\n                className={`py-2 px-1 rounded-lg text-xs sm:text-sm font-medium transition-all ${\n                  mode === 'text-to-image' \n                    ? 'bg-gray-700 text-white shadow' \n                    : 'text-gray-400 hover:text-white hover:bg-gray-800'\n                }`}\n              >\n                Text to Image\n              </button>\n              <button\n                onClick={() => setMode('mix-match')}\n                className={`py-2 px-1 rounded-lg text-xs sm:text-sm font-medium transition-all ${\n                  mode === 'mix-match' \n                    ? 'bg-gray-700 text-white shadow' \n                    : 'text-gray-400 hover:text-white hover:bg-gray-800'\n                }`}\n              >\n                Mix & Match\n              </button>\n              <button\n                onClick={() => setMode('describe')}\n                className={`py-2 px-1 rounded-lg text-xs sm:text-sm font-medium transition-all ${\n                  mode === 'describe' \n                    ? 'bg-gray-700 text-white shadow' \n                    : 'text-gray-400 hover:text-white hover:bg-gray-800'\n                }`}\n              >\n                Img to Prompt\n              </button>\n            </div>\n\n            {/* Content Logic */}\n            {(mode === 'mix-match' || mode === 'describe') && (\n              <div className=\"animate-in fade-in slide-in-from-top-4 duration-300\">\n                <label className=\"block text-lg font-semibold mb-3 text-gray-300\">\n                  {mode === 'mix-match' ? '1. Unggah Referensi Gambar' : 'Unggah Gambar Analisis'}\n                </label>\n                <div className=\"grid grid-cols-3 gap-4\">\n                  {imagePreviews.map((preview, index) => (\n                    <ImageUploadSlot\n                      key={index}\n                      imagePreview={preview}\n                      onImageSelect={(file) => handleImageSelect(index, file)}\n                      onImageRemove={() => handleImageRemove(index)}\n                      index={index}\n                    />\n                  ))}\n                </div>\n              </div>\n            )}\n\n            {(mode === 'text-to-image' || mode === 'mix-match') && (\n              <div className=\"animate-in fade-in slide-in-from-top-4 duration-300\">\n                <label htmlFor=\"prompt\" className=\"block text-lg font-semibold mb-3 text-gray-300\">\n                  {mode === 'text-to-image' ? '1. Tulis Prompt Anda' : '2. Tulis Instruksi Tambahan'}\n                </label>\n                <textarea\n                  id=\"prompt\"\n                  value={prompt}\n                  onChange={(e) => setPrompt(e.target.value)}\n                  placeholder={mode === 'text-to-image' ? \"Cth., Istana di atas awan, gaya lukisan minyak...\" : \"Cth., Ubah objek dalam gambar ini menjadi nuansa cyberpunk...\"}\n                  className=\"w-full h-32 p-3 bg-gray-900 border-2 border-gray-700 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition duration-200 text-gray-200 placeholder-gray-500 resize-none\"\n                />\n              </div>\n            )}\n\n             {mode === 'describe' && (\n              <div className=\"bg-indigo-900/20 border border-indigo-500/30 rounded-lg p-4 text-indigo-200 text-sm animate-in fade-in slide-in-from-top-4 duration-300\">\n                <p>AI akan menganalisis visual dan menghasilkan prompt teks yang bisa Anda gunakan kembali.</p>\n              </div>\n            )}\n            \n            <button\n              onClick={handleGenerateClick}\n              disabled={isGenerationDisabled}\n              className={`w-full py-3 px-6 font-bold text-lg rounded-lg transition-all duration-300 ease-in-out transform hover:scale-[1.02] flex items-center justify-center ${\n                isGenerationDisabled\n                  ? 'bg-gray-600 cursor-not-allowed text-gray-400'\n                  : 'bg-gradient-to-r from-purple-500 to-indigo-600 hover:from-purple-600 hover:to-indigo-700 text-white shadow-lg'\n              }`}\n            >\n              {isLoading ? (\n                <>\n                  <svg className=\"animate-spin -ml-1 mr-3 h-5 w-5 text-white\" xmlns=\"http://www.w3.org/2000/svg\" fill=\"none\" viewBox=\"0 0 24 24\">\n                    <circle className=\"opacity-25\" cx=\"12\" cy=\"12\" r=\"10\" stroke=\"currentColor\" strokeWidth=\"4\"></circle>\n                    <path className=\"opacity-75\" fill=\"currentColor\" d=\"M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z\"></path>\n                  </svg>\n                  Memproses...\n                </>\n              ) : (\n                mode === 'describe' ? 'Ekstrak Prompt' : 'Hasilkan Gambar'\n              )}\n            </button>\n             {error && <p className=\"text-red-400 text-center mt-2 font-medium\">{error}</p>}\n          </div>\n\n          {/* Output Panel */}\n          <div className=\"bg-gray-800/50 backdrop-blur-sm rounded-2xl p-6 shadow-2xl border border-gray-700 flex flex-col min-h-[400px]\">\n              <h3 className=\"text-xl font-semibold mb-4 text-gray-300 border-b border-gray-700 pb-2\">\n                Hasil {(mode === 'describe') ? 'Prompt' : 'Gambar'}\n              </h3>\n              \n              <div className=\"flex-1 flex flex-col items-center justify-center w-full relative\">\n                  {isLoading && (\n                      <div className=\"w-full h-full bg-gray-900/50 rounded-lg animate-pulse flex flex-col items-center justify-center min-h-[300px]\">\n                          <svg xmlns=\"http://www.w3.org/2000/svg\" className=\"h-12 w-12 text-indigo-500 mb-4 animate-bounce\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\">\n                              <path strokeLinecap=\"round\" strokeLinejoin=\"round\" strokeWidth={2} d=\"M13 10V3L4 14h7v7l9-11h-7z\" />\n                          </svg>\n                          <span className=\"text-gray-400\">Kecerdasan Buatan sedang meracik hasil...</span>\n                      </div>\n                  )}\n\n                  {!isLoading && generatedImage && (mode === 'text-to-image' || mode === 'mix-match') && (\n                      <div className=\"w-full h-full flex flex-col items-center animate-in zoom-in-95 duration-500\">\n                        <img src={generatedImage} alt=\"Generated\" className=\"object-contain w-full rounded-lg shadow-2xl max-h-[500px]\" />\n                        <button \n                          onClick={downloadImage}\n                          className=\"mt-6 flex items-center gap-2 bg-gradient-to-r from-emerald-500 to-teal-600 hover:from-emerald-600 hover:to-teal-700 text-white font-bold py-3 px-8 rounded-full shadow-lg transition-all transform hover:scale-105 active:scale-95\"\n                        >\n                          <svg xmlns=\"http://www.w3.org/2000/svg\" className=\"h-5 w-5\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\">\n                            <path strokeLinecap=\"round\" strokeLinejoin=\"round\" strokeWidth={2} d=\"M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4\" />\n                          </svg>\n                          Unduh Gambar\n                        </button>\n                      </div>\n                  )}\n\n                  {!isLoading && generatedText && mode === 'describe' && (\n                    <div className=\"w-full h-full flex flex-col animate-in fade-in duration-500\">\n                      <div className=\"bg-gray-900 p-6 rounded-lg border border-gray-700 text-gray-200 whitespace-pre-wrap font-mono text-sm overflow-y-auto max-h-[500px] flex-1 shadow-inner\">\n                        {generatedText}\n                      </div>\n                      <button \n                        onClick={() => {\n                          navigator.clipboard.writeText(generatedText);\n                          alert(\"Prompt berhasil disalin!\");\n                        }}\n                        className=\"mt-4 self-end text-sm bg-gray-700 hover:bg-gray-600 px-5 py-2 rounded-full text-white font-medium transition-all flex items-center gap-2 shadow-md active:scale-95\"\n                      >\n                        <svg xmlns=\"http://www.w3.org/2000/svg\" className=\"h-4 w-4\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\">\n                          <path strokeLinecap=\"round\" strokeLinejoin=\"round\" strokeWidth={2} d=\"M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3m2 4H10m0 0l3-3m-3 3l3 3\" />\n                        </svg>\n                        Salin Prompt\n                      </button>\n                    </div>\n                  )}\n\n                  {!isLoading && !generatedImage && !generatedText && (\n                      <div className=\"text-center text-gray-500 py-10\">\n                           <svg xmlns=\"http://www.w3.org/2000/svg\" className=\"h-20 w-20 mx-auto mb-4 opacity-20\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\">\n                              <path strokeLinecap=\"round\" strokeLinejoin=\"round\" strokeWidth={1} d=\"M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z\" />\n                          </svg>\n                          <p className=\"text-lg\">Silakan lakukan input di panel sebelah kiri untuk melihat hasil di sini.</p>\n                      </div>\n                  )}\n              </div>\n          </div>\n        </main>\n      </div>\n    </div>\n  );\n};\n\nexport default App;\n"
            }
          ]
        },
